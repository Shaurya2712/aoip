SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
GEMINI_API_KEY=your_gemini_api_key
GEMMA_MODEL_BULK=gemma-4-26b-a4b-it
GEMMA_MODEL_ANALYZE=gemma-4-31b-it
GEMMA_CONTEXT_TOKENS=262144
GEMMA_MAX_OUTPUT_TOKENS_BULK=2048
GEMMA_MAX_OUTPUT_TOKENS_ANALYZE=8192

# --- Gemini FREE tier (gemma-4-26b: 15 requests/min) — copy block to Render ---
AI_REQUESTS_PER_MINUTE=12
M2_BATCH_SIZE=8
M2_MAX_BATCHES_PER_RUN=12
M2_REEXPAND_DAYS=7
M3_MAX_KEYWORDS_PER_RUN=5
M3_BATCH_SIZE=1
M3_PYTRENDS_DELAY_SEC=45
M3_PYTRENDS_429_BACKOFF_SEC=90
M3_AI_ESTIMATE_ON_TRENDS_FAIL=true
M3_AI_ESTIMATE_MAX_PER_RUN=3
M4_MAX_KEYWORDS_PER_RUN=15
M7_MAX_KEYWORDS_PER_RUN=15

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AOIP/1.0 by yourusername
BACKEND_SECRET=change_this_to_a_random_string
ENV=production
# Optional: restrict CORS to your Vercel frontend (comma-separated)
FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app
